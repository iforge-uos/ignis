  "scripts": {
    "build": "OP_ACCOUNT=iforge.1password.com op run --no-masking --env-file=.env.prod -- bunx --bun vite build",
    "start": "OP_ACCOUNT=iforge.1password.com op run --no-masking --env-file=.env.prod -- bun run server.ts",
    "serve": "OP_ACCOUNT=iforge.1password.com op run --no-masking --env-file=.env.prod -- bunx --bun vite preview --port=3000",
    "dev": "OP_ACCOUNT=iforge.1password.com op run --no-masking --env-file=.env.dev -- bunx --bun vite dev --port=3000",
    "email": "OP_ACCOUNT=iforge.1password.com op run --no-masking --env-file=.env.dev -- bunx email preview src/email/templates",
    "email:check": "OP_ACCOUNT=iforge.1password.com op run --no-masking --env-file=.env.dev -- bunx email check"
  },
